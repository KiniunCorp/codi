# Multi-stage Dockerfile for CODI Slim container
# Rules-based CLI and API without external model dependencies

# Stage 1: Builder - Install dependencies and prepare the application
FROM python:3.12-slim AS builder

# Prevent Python from writing pyc files and buffering stdout/stderr
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install build dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy dependency metadata first for better caching of upstream wheels
COPY requirements.txt pyproject.toml README.md ./

# Pre-build wheels for third-party dependencies only (app sources copied later)
RUN pip install --upgrade pip setuptools wheel && \
    pip wheel --no-cache-dir --wheel-dir /wheels -r requirements.txt

# Copy application sources required to build the CODI wheel
COPY core/ ./core/
COPY cli/ ./cli/
COPY api/ ./api/
COPY patterns/ ./patterns/
COPY docker/ ./docker/
COPY docs/ ./docs/
COPY models/ ./models/
COPY Makefile ./Makefile

# Build wheel for the CODI project itself
RUN pip wheel --no-cache-dir --wheel-dir /wheels .

# Stage 2: Runtime - Minimal production image
FROM python:3.12-slim AS runtime

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    RULES_PATH=/opt/codi/patterns/rules.yml \
    LLM_ENABLED=false \
    AIRGAP=true

# Create non-root user for security
RUN groupadd -r codi && \
    useradd -r -g codi -m -d /opt/codi codi

# Install runtime dependencies only
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /opt/codi

# Copy wheels from builder stage
COPY --from=builder /wheels /wheels

# Install application from wheels
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir /wheels/*.whl && \
    rm -rf /wheels

# Copy application code and patterns
COPY --chown=codi:codi core/ ./core/
COPY --chown=codi:codi cli/ ./cli/
COPY --chown=codi:codi api/ ./api/
COPY --chown=codi:codi patterns/ ./patterns/
COPY --chown=codi:codi pyproject.toml ./

# Install the application in editable mode
RUN pip install --no-cache-dir -e .

# Create volume mount point for user projects
RUN mkdir -p /work && chown codi:codi /work
VOLUME ["/work"]

# Switch to non-root user
USER codi

# Expose API port
EXPOSE 8000

# Health check for API
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/ || exit 1

# Default command: start FastAPI server
# Users can override to run CLI commands, e.g.:
# docker run codi:slim codi all -f /work/Dockerfile -C /work
CMD ["uvicorn", "api.server:app", "--host", "0.0.0.0", "--port", "8000"]
